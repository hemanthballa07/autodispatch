# AutoDispatch — environment variable names (placeholders only; never commit real values).
# Copy to .env (gitignored) for local LIVE-mode experiments. Default mode is STUB.

WHATSAPP_MODE=STUB
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v21.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_TEMPLATE_FALLBACK_ENABLED=false

# Rider session JWTs (HS256). Required outside local dev.
JWT_SECRET=

# Admin API key — required outside local dev (default is only for local-only use).
ADMIN_API_KEY=

# Postgres / Redis (local docker-compose defaults exist; override in real envs)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=autodispatch
POSTGRES_USER=autodispatch
POSTGRES_PASSWORD=
REDIS_HOST=localhost
REDIS_PORT=6379
